# IMPORTANT:
#   Please edit only the .env file located in the root directory.
#   The /app/.env file is automatically overwritten every time you run `bun run dev`s.

# === Environment variables for /processing ===

# This file is only used during development.
# Staging/Production data is at https://github.com/FixMyBerlin/tilda-geo/settings/environments

ENVIRONMENT=development

# Database secrets
# Use 'localhost' for local development (connects to Docker container's exposed port)
# Docker environments use 'db' (Docker service name) in docker-compose.override.yml
DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_NAME=postgres
DATABASE_PASSWORD=mysecretpassword

# Application flags (processing container)
# REMINDER: Run `docker compose` from the repo root so this file is used (not a stale copy under /app).
# REMINDER: `docker compose up -d` picks up flag changes for already-created containers.
# In staging/production, these values come from GitHub environment variables (vars.PROCESSING_DIFFING_MODE, vars.PROCESSING_DIFFING_BBOX)
#
# Use `bun run test:processing-diff -- --help` (see app/scripts/ProcessingDiffRun/README.md) to set the following variables.
# Use .cursor/skills/test-processing-diff/SKILL.md to run processing via LLM.
#
# Geofabrik (internal extract when both username and password are set)
PROCESS_GEOFABRIK_OAUTH_OSM_USERNAME=your-osm-username
PROCESS_GEOFABRIK_OAUTH_OSM_PASSWORD=your-osm-password
# [INFO] Use "-internal" extracts with OAuth, see https://osm-internal.download.geofabrik.de/
PROCESS_GEOFABRIK_DOWNLOAD_URL=https://osm-internal.download.geofabrik.de/europe/germany/brandenburg-latest-internal.osm.pbf
# PROCESS_GEOFABRIK_DOWNLOAD_URL=https://download.geofabrik.de/europe/germany/berlin-latest.osm.pbf
SKIP_DOWNLOAD=1 # skips the download if a file already exists
# SKIP_UNCHANGED=1 # skips processing of unchanged code
# SKIP_WARM_CACHE=1 # skips cache warming, DEV only
# WAIT_FOR_FRESH_DATA=0 # waits till the given file is from today
# ID_FILTER='' # if not empty only the objects with these ids are processed. Example: `w123 w234`. See https://docs.osmcode.org/osmium/latest/osmium-getid.html
# [INFO] Staging: PROCESSING_DIFFING_MODE=reference (for nightly runs) | previous (for other deployments), Production: PROCESSING_DIFFING_MODE=off
# [INFO] When PROCESSING_DIFFING_MODE is not `off`, set PROCESSING_DIFFING_BBOX (MINLON,MINLAT,MAXLON,MAXLAT).
PROCESSING_DIFFING_MODE=off # off | previous | fixed | reference — required; use `bun run test:processing-diff` for overrides
# PROCESSING_DIFFING_MODE=previous # example when not using CLI
PROCESSING_DIFFING_BBOX=12.0380,51.6361,14.7271,53.2118 # Berlin + Brandenburg – Required when diffing_mode != off
# PROCESS_ONLY_TOPICS=parking # Only process those topics; Format: "topic,topic2,topic3"
# PROCESS_ONLY_BBOX=13.4178,52.4681,13.4550,52.4817 # Only process this bbox; Format: MINLON,MINLAT,MAXLON,MAXLAT
# OSM2PGSQL_LOG_LEVEL=info # 'debug' or empty (defaults to 'info') https://osm2pgsql.org/doc/manual-v1.html#logging

# === Environment variables for /app ===
# Vite: only VITE_* are exposed to client (import.meta.env). Server uses process.env.

# In staging/production, these come from GitHub environment variables (vars.VITE_APP_ORIGIN, vars.VITE_APP_ENV)
# Local dev: use http://127.0.0.1:5173 (OSM allows HTTP for 127.0.0.1 only). See docs/Local-Development-Domain-Setup.md
VITE_APP_ORIGIN=http://127.0.0.1:5173
VITE_APP_ENV=development # staging, production
# Generate with `openssl rand -base64 32`
SESSION_SECRET_KEY=

# E-Mail – Only on the server
MAILJET_APIKEY_PUBLIC=''
MAILJET_APIKEY_PRIVATE=''

# MAP API KEYS (See Bitwarden "TILDA Secrets")
# Source: https://account.mapbox.com/access-tokens/cl7079ubp09vs3osbzaovy3ge
MAPBOX_STYLE_ACCESS_TOKEN='' # pk.foo…
# Source: https://account.mapbox.com/access-tokens/clewefi6l20053yp1x8xpvopi
MAPBOX_PARKING_STYLE_ACCESS_TOKEN='' # pk.bar…

# DEVELOPMENT
# Use 'staging' to serve tiles without fresh local data.
# VITE_TILES_ENV=staging # 'development', 'staging'
VITE_DO_NOT_NAVIGATE=true # Disable client-side navigation (dev HMR workaround)

# LOGIN (See Bitwarden "TILDA Secrets")
# LOGIN auf master.apis.dev.openstreetmap.org
# Docs https://wiki.openstreetmap.org/wiki/Sandbox_for_editing
OSM_CLIENT_ID=uglV_cJniuc96GQT0-rO6sXsgJPZfat8PLCfv91qRC4
OSM_CLIENT_SECRET=KA…
# LOGIN auf www.openstreetmap.org
# OSM_CLIENT_ID=AiBpJN0aTIXuEP07qjVHU8ksVfn62uKLnV1eoGyTWZU
# OSM_CLIENT_SECRET=Dg…

# StaticDatasets (See Bitwarden "TILDA Secrets")
# Needed for upload and download
S3_KEY=A…
S3_SECRET=o…
S3_REGION=eu-central-1
# See https://s3.console.aws.amazon.com/s3/buckets/atlas-private?region=eu-central-1&bucketType=general&tab=objects
S3_BUCKET=atlas-private

# Per Environment Config
# ENV: Development
ATLAS_API_KEY=m… # (See Bitwarden "TILDA Secrets")
# ENV: Staging
# ATLAS_API_KEY=m… # (See Bitwarden "TILDA Secrets")
# ENV: Production
# ATLAS_API_KEY=N… # (See Bitwarden "TILDA Secrets")

# MAPROULETTE: https://maproulette.org/user/profile for user `osm-verkehrswende-org`
MAPROULETTE_API_KEY=19361|5a3f1788-e18c-4d64-a343-f00bdf8e2bd7

# TESTING: Enable Playwright E2E testing mode
VITE_PLAYWRIGHT_ENABLED=true

# REMINDER:
# Update `/app/src/env.d.ts` when adding new VITE_* variables.

# Deployment URLs
# In staging/production, these values come from GitHub environment variables (vars.APP_URL, vars.CACHELESS_URL, vars.TILES_URL)
# These can be empty for development. They are only needed for SSL certs and deployment.
APP_URL=''
CACHELESS_URL=''
TILES_URL=''
