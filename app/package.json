{
  "name": "tilda-geo",
  "version": "2.0.0",
  "author": "FixMyCity <hello@fixmycity.de>",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "start": "vite preview --host 127.0.0.1 --port 4000",
    "dev": "FORCE_COLOR=1 vite dev --host 127.0.0.1 --port 5173",
    "predev": "bun scripts/predev/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "bleach": "rm -rf node_modules/ && rm -rf .output/ && bun install",
    "bleach:full": "rm bun.lock && bun run bleach",
    "cleanup:docker": "bun scripts/docker-cleanup/index.ts",
    "cleanup:knip": "knip",
    "studio": "prisma studio",
    "migrate": "prisma migrate dev",
    "migrate:create": "bun run --sequential migrate:create:*",
    "migrate:create:1write": "prisma migrate dev --create-only",
    "migrate:create:2format": "biome format --write ./prisma/migrations",
    "migrate:create:3open": "code $(find ./prisma/migrations -type f -name 'migration.sql' -cmin -1 | head -n 1)",
    "migrate:check": "prisma migrate status",
    "migrate:compare": "git diff origin/main... -- prisma/migrations",
    "seed": "bun run predev && bun run migrate && prisma migrate reset && prisma db seed",
    "seed:full": "bun run seed && bun run StaticDatasets:update -- --env=dev",
    "type-check": "tsc --noEmit",
    "type-check:deploy": "sh -c 'bun run StaticDatasets:unlink && bun run type-check; EXIT_CODE=$?; bun run StaticDatasets:link; exit $EXIT_CODE'",
    "lint": "biome lint --write --unsafe && eslint . --fix",
    "format": "bun run --parallel format:*",
    "format:main": "biome format --write .",
    "format:StaticDatasets": "biome format --write --config-path=scripts/StaticDatasets/biome.json --skip-parse-errors scripts/StaticDatasets/geojson",
    "check": "bun run --parallel type-check lint format test:run",
    "regions": "bun run --sequential regions:masks regions:configs",
    "regions:masks": "bun run --sequential regions:masks:*",
    "regions:masks:1prepare": "bun ./scripts/StaticDatasets/createMasks.ts",
    "regions:masks:2format": "biome format --write scripts/StaticDatasets/geojson/masks",
    "regions:masks:3upload": "bun ./scripts/StaticDatasets/updateStaticDatasets.ts --folder-filter=masks/",
    "regions:configs": "bun run --sequential regions:configs:*",
    "regions:configs:1write": "bun src/components/regionen/pageRegionSlug/hooks/useQueryState/useCategoriesConfig/v2/saveConfigs.ts",
    "regions:configs:2format": "biome format --write src/components/regionen/pageRegionSlug/hooks/useQueryState/useCategoriesConfig/v2/configs",
    "test": "vitest watch",
    "test:run": "vitest run --passWithNoTests",
    "test:processing-diff": "bun ./scripts/ProcessingDiffRun/run.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "mailpreview": "VITE_APP_ORIGIN=http://127.0.0.1:5173 email dev --dir mailers",
    "MapboxStyles:update": "bun run --sequential MapboxStyles:update:*",
    "MapboxStyles:update:1process": "bun ./scripts/MapboxStyles/process.ts",
    "MapboxStyles:update:2lint": "bun run lint",
    "MapboxStyles:update:3format": "bun run format",
    "MapboxStyles:update:4github": "github",
    "StaticDatasets:update": "bun ./scripts/StaticDatasets/updateStaticDatasets.ts --folder-filter=",
    "StaticDatasets:updateDownloadSources": "bun --env-file=.env ./scripts/StaticDatasets/updateDownloadSources.ts --folder-filter=",
    "StaticDatasets:deleteAll:dev": "echo \"Reminder: We cannot use this on staging, production, see https://github.com/FixMyBerlin/private-issues/issues/2283\" && bun --env-file=.env --env-file=./scripts/StaticDatasets/.env.development ./scripts/StaticDatasets/deleteAllStaticDatasets.ts",
    "StaticDatasets:link": "ln -sf ../../../../tilda-static-data/geojson scripts/StaticDatasets",
    "StaticDatasets:unlink": "rm -f scripts/StaticDatasets/geojson",
    "MapboxTilesets:update": "bun ./scripts/MapboxTilesets/process.ts",
    "TranslationAnalysis:update": "bun ./scripts/TranslationAnalysis/analyze.ts",
    "MaprouletteCreate": "bun run scripts/MaprouletteCreate/process.ts",
    "MaprouletteRebuild": "bun run scripts/MaprouletteRebuild/process.ts",
    "Maproulette:help": "echo -e '\\033[0;32m Help: Use `bun run MaprouletteCreate -- --filter FOOBAR` \\033[0m' && echo -e '\\033[0;32m Rebuild: Use `bun run MaprouletteRebuild -- --filter FOOBAR` \\033[0m'",
    "update": "bun scripts/updatePackages/index.ts",
    "release": "gh pr create --base main --head develop --title \"Release $(date '+%Y-%m-%d')\" --body \"\"",
    "postinstall": "prisma generate",
    "prepare": "cd .. && husky app/.husky"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "browserslist": [
    "defaults",
    "last 2 IE major versions",
    "last 4 Edge major versions"
  ],
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@date-fns/utc": "2.1.1",
    "@headlessui/react": "2.2.9",
    "@json2csv/plainjs": "7.0.6",
    "@mapbox/mapbox-gl-draw": "1.5.1",
    "@maptiler/geocoding-control": "2.1.7",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@react-email/components": "1.0.11",
    "@tanstack/form-core": "^1.28.6",
    "@tanstack/react-devtools": "0.10.1",
    "@tanstack/react-form": "1.28.6",
    "@tanstack/react-form-devtools": "^0.2.20",
    "@tanstack/react-query": "5.96.1",
    "@tanstack/react-query-devtools": "5.96.1",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.16",
    "@tanstack/router-core": "^1.168.9",
    "@turf/bbox": "7.3.4",
    "@turf/boolean-intersects": "7.3.4",
    "@turf/helpers": "7.3.4",
    "@turf/truncate": "7.3.4",
    "@turf/turf": "7.3.4",
    "adler-32": "1.3.1",
    "better-auth": "1.5.6",
    "betterknown": "1.2.0",
    "date-fns": "4.1.0",
    "dompurify": "3.3.3",
    "es-toolkit": "^1.45.1",
    "geojson": "0.5.0",
    "h3": "^2.0.1-rc.20",
    "immer": "11.1.4",
    "js-cookie": "3.0.5",
    "jsts": "2.12.1",
    "jsurl2": "2.2.0",
    "maplibre-gl": "5.21.1",
    "nitro": "npm:nitro-nightly@latest",
    "node-mailjet": "6.0.11",
    "nuqs": "2.8.9",
    "pg": "8.20.0",
    "pmtiles": "4.4.0",
    "postcss": "8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intl": "10.1.1",
    "react-map-gl": "8.1.0",
    "react-remark": "2.1.0",
    "slugify": "1.6.8",
    "tailwind-merge": "3.5.0",
    "tiny-invariant": "1.3.3",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1021.0",
    "@biomejs/biome": "^2.4.10",
    "@clack/prompts": "1.2.0",
    "@heroicons/react": "2.2.0",
    "@placemarkio/check-geojson": "0.1.14",
    "@playwright/test": "1.59.0",
    "@react-email/preview-server": "5.2.10",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/router-plugin": "1.167.12",
    "@testing-library/jest-dom": "6.9.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.11",
    "@types/js-cookie": "3.0.6",
    "@types/mapbox__mapbox-gl-draw": "1.4.9",
    "@types/preview-email": "3.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/spritesmith": "3.4.5",
    "@types/web": "0.0.345",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.11",
    "dotenv": "17.3.1",
    "eslint": "10.1.0",
    "eslint-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "favicons": "7.2.0",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "knip": "6.1.1",
    "parse-gitignore": "2.0.0",
    "picomatch": "^4.0.4",
    "preview-email": "3.1.1",
    "prisma": "7.6.0",
    "react-email": "5.2.10",
    "sharp": "0.34.5",
    "spritesmith": "3.5.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vitest": "4.1.2"
  }
}
