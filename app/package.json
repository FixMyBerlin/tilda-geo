{
  "name": "tilda-geo",
  "version": "2.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "author": "FixMyCity <hello@fixmycity.de>",
  "type": "module",
  "scripts": {
    "start": "vite preview --host 127.0.0.1 --port 4000",
    "dev": "FORCE_COLOR=1 vite dev --host 127.0.0.1 --port 5173",
    "predev": "bun run --sequential predev:*",
    "predev:1copy-env": "bun scripts/predev/copyEnv.ts",
    "predev:2env-contract": "bun run env-check",
    "predev:3docker": "bun scripts/predev/checkDocker.ts",
    "predev:4migration": "bun scripts/predev/checkMigration.ts --non-interactive",
    "predev:5package-updates": "bun scripts/predev/checkPackageUpdates.ts",
    "db-pull": "bun --env-file=../.env scripts/db-pull/run.ts",
    "db-pull:pull": "bun --env-file=../.env scripts/db-pull/pull.ts",
    "db-pull:restore": "bun --env-file=../.env scripts/db-pull/restore-local.ts",
    "build": "vite build",
    "preview": "vite preview",
    "bleach": "rm -rf node_modules/ && rm -rf .output/ && bun install",
    "bleach-full": "rm bun.lock && bun run bleach",
    "cleanup-docker": "bun scripts/docker-cleanup/index.ts",
    "cleanup-knip": "knip",
    "env-check:verify-manifest": "bun ../.github/scripts/verify-env-manifest.ts",
    "env-check:docs": "bun run --sequential env-check:docs:*",
    "env-check:docs:1sync": "bun ../.github/scripts/generate-github-readme.ts",
    "env-check:docs:2format": "bun run format",
    "env-check": "bun run --parallel env-check:*",
    "studio": "prisma studio",
    "migrate": "prisma migrate dev",
    "migrate-create": "bun run --sequential migrate-create:*",
    "migrate-create:1write": "prisma migrate dev --create-only",
    "migrate-create:2format": "oxfmt --write ./prisma/migrations",
    "migrate-create:3open": "code $(find ./prisma/migrations -type f -name 'migration.sql' -cmin -1 | head -n 1)",
    "migrate-check": "prisma migrate status",
    "migrate-compare": "git diff origin/main... -- prisma/migrations",
    "seed": "bun run predev && bun run migrate && prisma migrate reset && prisma db seed",
    "seed-full": "bun run seed && bun run static-datasets-update -- --env=dev",
    "type-check": "tsc --noEmit",
    "type-check-deploy": "sh -c 'bun run static-datasets-unlink && bun run type-check; EXIT_CODE=$?; bun run static-datasets-link; exit $EXIT_CODE'",
    "lint": "biome lint --write --unsafe && eslint . --fix",
    "format": "bun run --parallel format:*",
    "format:main": "oxfmt --write .",
    "format:github": "cd .. && oxfmt --write .github -c app/oxfmt.config.ts",
    "format:docs": "cd .. && oxfmt --write docs -c app/oxfmt.config.ts",
    "format:StaticDatasets": "oxfmt --write scripts/StaticDatasets/geojson",
    "check": "bun run --parallel type-check lint format test-run",
    "regions": "bun run --sequential regions:masks regions:configs",
    "regions:masks": "bun run --sequential regions:masks:*",
    "regions:masks:1prepare": "bun ./scripts/StaticDatasets/createMasks.ts",
    "regions:masks:2format": "oxfmt --write scripts/StaticDatasets/geojson/masks",
    "regions:masks:3upload": "bun ./scripts/StaticDatasets/updateStaticDatasets.ts --folder-filter=masks/",
    "regions:configs": "bun run --sequential regions:configs:*",
    "regions:configs:1write": "bun src/components/regionen/pageRegionSlug/hooks/useQueryState/useCategoriesConfig/v2/saveConfigs.ts",
    "regions:configs:2format": "oxfmt --write src/components/regionen/pageRegionSlug/hooks/useQueryState/useCategoriesConfig/v2/configs",
    "test": "vitest watch",
    "test-run": "vitest run --passWithNoTests",
    "test-e2e": "playwright test",
    "test-e2e-ui": "playwright test --ui",
    "test-e2e-debug": "playwright test --debug",
    "mailpreview": "VITE_APP_ORIGIN=http://127.0.0.1:5173 email dev --dir mailers",
    "processing-generate-command": "bun ./scripts/processing-generate-command/index.ts -- --skip-download 1 --skip-warm-cache 1 --skip-unchanged 0",
    "mapbox-styles-update": "bun run --sequential mapbox-styles-update:*",
    "mapbox-styles-update:1process": "bun ./scripts/MapboxStyles/process.ts",
    "mapbox-styles-update:2lint": "bun run lint",
    "mapbox-styles-update:3format": "bun run format",
    "mapbox-styles-update:4github": "github",
    "static-datasets-update": "bun ./scripts/StaticDatasets/updateStaticDatasets.ts --folder-filter=",
    "static-datasets-download-sources": "bun ./scripts/StaticDatasets/updateDownloadSources.ts --folder-filter=",
    "static-datasets-delete-all-dev": "echo \"Reminder: We cannot use this on staging, production, see https://github.com/FixMyBerlin/private-issues/issues/2283\" && bun ./scripts/StaticDatasets/deleteAllStaticDatasets.ts",
    "static-datasets-link": "ln -sf ../../../../tilda-static-data/geojson scripts/StaticDatasets",
    "static-datasets-unlink": "rm -f scripts/StaticDatasets/geojson",
    "mapbox-tilesets-update": "bun ./scripts/MapboxTilesets/process.ts",
    "translation-analysis-update": "bun ./scripts/TranslationAnalysis/analyze.ts",
    "maproulette-create": "bun run scripts/MaprouletteCreate/process.ts",
    "maproulette-rebuild": "bun run scripts/MaprouletteRebuild/process.ts",
    "maproulette-help": "echo -e '\\033[0;32m Help: Use `bun run maproulette-create -- --filter FOOBAR` \\033[0m' && echo -e '\\033[0;32m Rebuild: Use `bun run maproulette-rebuild -- --filter FOOBAR` \\033[0m'",
    "update": "bun scripts/updatePackages/index.ts",
    "release": "gh pr create --base main --head develop --title \"Release $(date '+%Y-%m-%d')\" --body \"\"",
    "postinstall": "bun scripts/prisma-generate-placeholder/index.ts",
    "prepare": "cd .. && husky app/.husky"
  },
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@date-fns/utc": "2.1.1",
    "@headlessui/react": "2.2.9",
    "@json2csv/plainjs": "7.0.6",
    "@maptiler/geocoding-control": "2.1.7",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@react-email/components": "1.0.11",
    "@tanstack/form-core": "^1.28.6",
    "@tanstack/react-devtools": "0.10.1",
    "@tanstack/react-form": "1.28.6",
    "@tanstack/react-form-devtools": "^0.2.20",
    "@tanstack/react-query": "5.96.2",
    "@tanstack/react-query-devtools": "5.96.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.16",
    "@tanstack/router-core": "^1.168.9",
    "@turf/bbox": "7.3.4",
    "@turf/boolean-intersects": "7.3.4",
    "@turf/helpers": "7.3.4",
    "@turf/truncate": "7.3.4",
    "@turf/turf": "7.3.4",
    "adler-32": "1.3.1",
    "better-auth": "1.6.0",
    "betterknown": "1.2.0",
    "date-fns": "4.1.0",
    "dompurify": "3.3.3",
    "es-toolkit": "^1.45.1",
    "geojson": "0.5.0",
    "h3": "^2.0.1-rc.20",
    "immer": "11.1.4",
    "js-cookie": "3.0.5",
    "jsts": "2.12.1",
    "jsurl2": "2.2.0",
    "maplibre-gl": "5.22.0",
    "nitro": "npm:nitro-nightly@latest",
    "node-mailjet": "6.0.11",
    "nuqs": "2.8.9",
    "pg": "8.20.0",
    "pmtiles": "4.4.0",
    "postcss": "8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intl": "10.1.1",
    "react-map-gl": "8.1.0",
    "react-remark": "2.1.0",
    "slugify": "1.6.9",
    "tailwind-merge": "3.5.0",
    "terra-draw": "1.27.0",
    "terra-draw-maplibre-gl-adapter": "1.3.0",
    "tiny-invariant": "1.3.3",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1025.0",
    "@biomejs/biome": "^2.4.10",
    "@clack/prompts": "1.2.0",
    "@heroicons/react": "2.2.0",
    "@placemarkio/check-geojson": "0.1.14",
    "@playwright/test": "1.59.1",
    "@react-email/preview-server": "5.2.10",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/router-plugin": "1.167.12",
    "@testing-library/jest-dom": "6.9.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.11",
    "@types/js-cookie": "3.0.6",
    "@types/preview-email": "3.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/spritesmith": "3.4.5",
    "@types/web": "0.0.345",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.11",
    "dotenv": "17.4.1",
    "eslint": "10.2.0",
    "eslint-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "favicons": "7.2.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "knip": "6.3.0",
    "oxfmt": "^0.44.0",
    "parse-gitignore": "2.0.0",
    "picomatch": "^4.0.4",
    "preview-email": "3.1.3",
    "prisma": "7.6.0",
    "react-email": "5.2.10",
    "sharp": "0.34.5",
    "spritesmith": "3.5.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "^8.0.5",
    "vitest": "4.1.2"
  },
  "browserslist": [
    "defaults",
    "last 2 IE major versions",
    "last 4 Edge major versions"
  ],
  "engines": {
    "bun": ">=1.3.9"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
