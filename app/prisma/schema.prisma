// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgres"
  schemas  = ["prisma"]
}

generator client {
  provider            = "prisma-client"
  output              = "../src/prisma/generated"
  runtime             = "bun"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

model User {
  // Better Auth core fields
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  email         String   @unique // Placeholder-E-Mail from better auth. Used as Contact email when provided by user, editable via settings.
  emailVerified Boolean  @default(false)

  // OSM-sourced fields (synced from OSM API on each login via mapProfileToUser)
  osmId          Int     @unique // OSM user ID (from OSM API user.id)
  osmName        String? // OSM display name (from OSM API user.display_name) - mapped to Better Auth 'name'
  osmDescription String? // OSM profile description (from OSM API user.description) - synced on login, can be cleared by admin
  osmAvatar      String? // OSM avatar URL (from OSM API user.img.href) - mapped to Better Auth 'image'

  // User-managed fields (editable by user via settings)
  firstName String? // User's first name (editable via UserForm)
  lastName  String? // User's last name (editable via UserForm)

  // App-managed fields
  role            UserRoleEnum   @default(USER) // User role (USER/ADMIN) - set on user creation, managed by admins
  accessedRegions Json?          @default("[]") // Region access tracking (JSON array) - managed by app logic
  //
  tokens          Token[]
  sessions        Session[]
  accounts        Account[]
  verifications   Verification[]
  Membership      Membership[]
  Note            Note[]
  NoteComment     NoteComment[]
  qaEvaluations   QaEvaluation[]

  @@map("User")
  @@schema("prisma")
}

enum UserRoleEnum {
  USER
  ADMIN

  @@schema("prisma")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
  @@schema("prisma")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  //
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  //
  @@unique([providerId, accountId])
  @@index([userId])
  @@map("Account")
  @@schema("prisma")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?

  //
  @@unique([identifier, value])
  @@map("Verification")
  @@schema("prisma")
}

model Token {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  //
  hashedToken String
  type        TokenType
  expiresAt   DateTime
  sentTo      String
  //
  user        User      @relation(fields: [userId], references: [id])
  userId      String

  @@unique([hashedToken, type])
  @@map("Token")
  @@schema("prisma")
}

enum TokenType {
  RESET_PASSWORD

  @@schema("prisma")
}

enum RegionStatus {
  PUBLIC
  PRIVATE
  DEACTIVATED

  @@schema("prisma")
}

model Region {
  id        Int          @id @default(autoincrement())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  //
  slug      String       @unique
  promoted  Boolean      @default(false)
  status    RegionStatus @default(PUBLIC)

  Membership Membership[]
  uploads    Upload[]
  Note       Note[]
  qaConfigs  QaConfig[]

  @@map("Region")
  @@schema("prisma")
}

model Membership {
  id Int @id @default(autoincrement())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  region   Region @relation(fields: [regionId], references: [id])
  regionId Int

  @@unique([regionId, userId])
  @@map("Membership")
  @@schema("prisma")
}

model Upload {
  id                Int                 @id @default(autoincrement())
  createdAt         DateTime            @default(now())
  createdBy         UploadCreatedByEnum @default(SCRIPT)
  updatedAt         DateTime            @updatedAt
  //
  slug              String              @unique
  configs           Json
  public            Boolean             @default(false)
  hideDownloadLink  Boolean             @default(false)
  mapRenderFormat   MapRenderFormatEnum
  mapRenderUrl      String
  githubUrl         String
  // One of them is missing when `dataSourceType: 'external'` (because external sources are "either or")
  pmtilesUrl        String?
  geojsonUrl        String?
  //
  externalSourceUrl String?
  cacheTtlSeconds   Int?                @default(86400)
  //
  systemLayer       Boolean             @default(false)
  //
  regions           Region[]

  @@map("Upload")
  @@schema("prisma")
}

model StaticDatasetCategory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Same string as Upload.configs[].category (e.g. bb/Netzkonzeption). Globally unique.
  key         String @unique @db.VarChar(191)

  /// First path segment (before first `/`), e.g. bb from bb/Netzkonzeption.
  groupKey    String @db.VarChar(191)

  /// Rest after first `/`, e.g. Netzkonzeption.
  categoryKey String @db.VarChar(191)

  /// Display order in the region sidebar; supports fractional values (e.g. 1.5).
  sortOrder Float

  /// Max lengths: `staticDatasetCategoryDisplayLimits.ts`.
  title    String  @db.VarChar(40)
  subtitle String? @db.VarChar(100)

  @@unique([groupKey, categoryKey])
  @@index([groupKey, sortOrder, categoryKey])
  @@map("StaticDatasetCategory")
  @@schema("prisma")
}

enum UploadCreatedByEnum {
  USER
  SCRIPT

  @@schema("prisma")
}

enum MapRenderFormatEnum {
  pmtiles
  geojson

  @@schema("prisma")
}

model Note {
  id           Int           @id @default(autoincrement())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  //
  author       User          @relation(fields: [userId], references: [id])
  userId       String
  //
  region       Region        @relation(fields: [regionId], references: [id])
  regionId     Int
  //
  subject      String
  body         String?
  resolvedAt   DateTime?
  latitude     Float
  longitude    Float
  // osm_type    String?       @db.VarChar
  // osm_id      String?
  //
  noteComments NoteComment[]

  @@map("Note")
  @@schema("prisma")
}

model NoteComment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  //
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId    Int
  //
  body      String

  @@map("NoteComment")
  @@schema("prisma")
}

// QA System Models
model QaConfig {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug     String // e.g., "euvm_parking_capacity"
  label    String // e.g., "eUVM Parkplätze Kapazität"
  isActive Boolean @default(true)

  // Reference to existing data table (with schema prefix)
  mapTable String // e.g., "public.qa_parkings_euvm"

  // Map attribution for the source
  mapAttribution String? // e.g., "QA Data: tilda-geo.de"

  // Thresholds for automatic system evaluation
  goodThreshold               Float @default(0.1) // relative <= 0.1 difference = GOOD
  needsReviewThreshold        Float @default(0.2) // relative <= 0.2 difference = NEEDS_REVIEW
  absoluteDifferenceThreshold Int   @default(4) // absolute difference <= this value is not considered a change

  region   Region @relation(fields: [regionId], references: [id])
  regionId Int

  qaEvaluations QaEvaluation[]

  @@unique([regionId, slug])
  @@map("QaConfig")
  @@schema("prisma")
}

model QaEvaluation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reference to row in existing data table (could be voronoi, h3, etc.)
  areaId String // Links to public.qa_parkings_euvm.id

  // System automatic evaluation (based on thresholds)
  systemStatus QaSystemStatus @default(NEEDS_REVIEW)

  // Manual user evaluation status
  userStatus QaEvaluationStatus? // NULL means no user decision yet

  // Optional evaluation text/reasoning (only for user evaluations)
  body String?

  // Snapshot of data used for this evaluation
  decisionData Json?

  config   QaConfig @relation(fields: [configId], references: [id])
  configId Int

  // Evaluator tracking - either system or user
  evaluatorType QaEvaluatorType @default(SYSTEM)
  author        User?           @relation(fields: [userId], references: [id])
  userId        String?

  // Remove unique constraint to allow evaluation history
  // @@unique([configId, areaId])  // REMOVED

  @@map("QaEvaluation")
  @@schema("prisma")
}

enum QaSystemStatus {
  GOOD // Green - no review needed
  NEEDS_REVIEW // Yellow - medium difference
  PROBLEMATIC // Red - large difference

  @@schema("prisma")
}

enum QaEvaluationStatus {
  OK_STRUCTURAL_CHANGE // "Diff OK, caused by structural change in the area like construction"
  OK_REFERENCE_ERROR // "Diff OK, caused by wrong past/reference data"
  NOT_OK_DATA_ERROR // "Diff not OK, current data needs to be fixed"
  NOT_OK_PROCESSING_ERROR // "Diff not OK, processing needs to be fixed"
  OK_QA_TOOLING_ERROR // "Diff OK, caused by methodical error in QA tooling (geometries/definitions)"

  @@schema("prisma")
}

enum QaEvaluatorType {
  SYSTEM
  USER

  @@schema("prisma")
}
